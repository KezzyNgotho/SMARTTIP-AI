{
  "manifest_version": 3,
  "name": "SmartTip DApp",
  "version": "1.0",
  "description": "AI-powered tipping for creators",
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "content_scripts": [
    {
      "matches": [
        "*://rumble.com/*",
        "*://*.rumble.com/*",
        "*://youtube.com/*",
        "*://*.youtube.com/*",
        "*://twitch.tv/*",
        "*://*.twitch.tv/*",
        "*://tiktok.com/*",
        "*://*.tiktok.com/*"
      ],
      "js": ["contentScript.js"],
      "all_frames": true
    }
  ],
  "permissions": ["storage", "activeTab", "scripting", "tabs"]
}
