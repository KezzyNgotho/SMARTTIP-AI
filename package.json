{
  "name": "smarttip-dapp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:app": "vite",
    "dev:extension": "vite build --watch",
    "dev:assets": "node scripts/prepare-extension.mjs --watch",
    "start:all": "concurrently -k -n APP,EXT,ASSETS \"npm:dev:app\" \"npm:dev:extension\" \"npm:dev:assets\"",
    "build": "vite build",
    "build:extension": "vite build && node scripts/prepare-extension.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@langchain/core": "^1.1.34",
    "@scure/bip39": "^2.0.1",
    "@tetherto/wdk-wallet-evm": "^1.0.0-beta.10",
    "buffer": "^6.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "sodium-javascript": "^0.8.0",
    "xstate": "^5.28.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.2",
    "vite": "^5.4.8"
  }
}
